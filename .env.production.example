# ===== Public URLs =====
PUBLIC_APP_URL=https://app.example.com
PUBLIC_API_URL=https://api.example.com/api

# ===== Database =====
MYSQL_ROOT_PASSWORD=replace-with-a-root-password
DATABASE_URL=mysql://dobrokot:change-me@mysql:3306/dobrokot
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_USER=dobrokot
DATABASE_PASSWORD=change-me
DATABASE_NAME=dobrokot
DATABASE_CONNECTION_LIMIT=10

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== Backend =====
PORT=4000
NODE_ENV=production
CORS_ORIGIN=https://app.example.com
JWT_SECRET=replace-with-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== Frontend (Next.js) =====
NEXTAUTH_URL=https://app.example.com
NEXTAUTH_SECRET=replace-with-another-random-secret-at-least-32-chars
NEXT_PUBLIC_API_URL=https://api.example.com/api

# ===== Email (SMTP) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM="DoBroKot <noreply@example.com>"
