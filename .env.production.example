PUBLIC_APP_URL=https://app.dobrokot.online
PUBLIC_API_URL=https://api.dobrokot.online/api

# ===== Database =====
MYSQL_ROOT_PASSWORD=zxcASD1234567890
# В compose-сети api ходит до MySQL по имени сервиса `mysql`, не `localhost`.
DATABASE_URL="mysql://dobrokot:zxcASD1234567890@mysql:3306/dobrokot"
DATABASE_HOST=mysql
DATABASE_PORT=3306
DATABASE_USER=dobrokot
DATABASE_PASSWORD=zxcASD1234567890
DATABASE_NAME=dobrokot
DATABASE_CONNECTION_LIMIT=5

# ===== Backend =====
PORT=4000
NODE_ENV=production
JWT_SECRET=whdIUHIUQ6gwudhwa1927hUGIYYwu271jhdwuHH2jdjayw
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Должно совпадать с PUBLIC_APP_URL — иначе браузер словит CORS на запросах к API.
CORS_ORIGIN=https://app.dobrokot.online

# ===== Frontend (Next.js) =====
# Должно совпадать с PUBLIC_API_URL (https + правильный домен).
# Подставляется на этапе сборки Next.js (см. args в docker-compose.prod.yml),
# так что при изменении этого URL надо пересобирать образ `web`.
NEXT_PUBLIC_API_URL=https://api.dobrokot.online/api
NEXTAUTH_URL=https://app.dobrokot.online
NEXTAUTH_SECRET=dwaiwaiu78212GUGueg67guioejiHGHG197843kOPKMOJ12he
