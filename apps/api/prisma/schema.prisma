generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  runtime                = "nodejs"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
  importFileExtension    = ""
}

datasource db {
  provider = "mysql"
}

// ─── Users ───────────────────────────────────────────────

model User {
  id                    String            @id @default(uuid())
  email                 String            @unique
  passwordHash          String
  name                  String
  phone                 String?
  role                  UserRole          @default(OWNER)
  city                  String?
  latitude              Float?
  longitude             Float?
  avatarUrl             String?
  isVerified            Boolean           @default(false)
  subscriptionPlan      SubscriptionPlan?
  subscriptionExpiresAt DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  refreshTokens RefreshToken[]
  clinic        Clinic?

  @@index([city])
  @@index([role])
  @@index([subscriptionExpiresAt])
}

enum SubscriptionPlan {
  WEEK
  MONTH
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(500)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

enum UserRole {
  OWNER
  CLINIC
  ADMIN
}

enum AnimalType {
  DOG
  CAT
}

model Partner {
  id              Int         @id @default(autoincrement())
  rank            PartnerRank
  title           String
  imageUrl        String      @map("image_url") @db.VarChar(2048)
  type            PartnerType
  bloodDonations  Int         @map("blood_donations")
  plasmaDonations Int         @map("plasma_donations")

  @@index([rank])
  @@index([type])
  @@index([title])
  @@map("partners")
}

enum PartnerRank {
  LEGENDARY_DONOR
  RELIABLE_ASSISTANT
}

enum PartnerType {
  VETERINARY_CLINIC
  SHELTER
}

model Donor {
  id              String @id @default(uuid())
  imageUrl        String @map("image_url") @db.VarChar(2048)
  title           String
  address         String
  bloodDonations  Int    @map("blood_donations")
  plasmaDonations Int    @map("plasma_donations")

  @@index([title])
  @@index([address])
  @@map("donors")
}

// ─── Clinics ─────────────────────────────────────────────

model Clinic {
  id                 String                   @id @default(uuid())
  userId             String                   @unique
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title              String                   @db.VarChar(191)
  description        String?                  @db.Text
  phone              String?                  @db.VarChar(32)
  contactEmail       String?                  @db.VarChar(191)
  websiteUrl         String?                  @db.VarChar(2048)
  address            String?                  @db.VarChar(255)
  city               String?                  @db.VarChar(100)
  latitude           Float?
  longitude          Float?
  workingHours       String?                  @db.VarChar(255)
  licenseNo          String?                  @db.VarChar(100)
  verificationStatus ClinicVerificationStatus @default(PENDING)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  bloodInventory BloodInventory[]

  @@index([city])
  @@index([title])
  @@index([verificationStatus])
}

enum ClinicVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ─── Blood Inventory ─────────────────────────────────────

model BloodInventory {
  id           String               @id @default(uuid())
  clinicId     String
  clinic       Clinic               @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  animalType   AnimalType
  bloodType    String               @db.VarChar(20)
  volumeMl     Float?
  unitsCount   Int                  @default(1)
  donationDate DateTime?
  expiresAt    DateTime?
  status       BloodInventoryStatus @default(AVAILABLE)
  notes        String?              @db.Text
  donorRef     String?              @db.VarChar(191)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([clinicId])
  @@index([animalType, bloodType, status])
  @@index([expiresAt])
}

enum BloodInventoryStatus {
  AVAILABLE
  RESERVED
  USED
  EXPIRED
}

// ─── Partnership Requests ────────────────────────────────

model PartnershipRequest {
  id                String                   @id @default(uuid())
  contactName       String                   @db.VarChar(191)
  contactEmail      String                   @db.VarChar(191)
  contactPhone      String?                  @db.VarChar(32)
  clinicTitle       String                   @db.VarChar(191)
  city              String?                  @db.VarChar(100)
  message           String?                  @db.Text
  status            PartnershipRequestStatus @default(NEW)
  processedAt       DateTime?
  processedBy       String?
  provisionedUserId String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([status])
  @@index([contactEmail])
}

enum PartnershipRequestStatus {
  NEW
  IN_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}
