{
  "name": "@dobrokot/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:push": "prisma db push --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts && prisma generate --config prisma.config.ts",
    "db:deploy": "prisma migrate deploy --config prisma.config.ts"
  },
  "dependencies": {
    "@dobrokot/shared": "workspace:*",
    "@prisma/adapter-mariadb": "^7.7.0",
    "@prisma/client": "^7.0.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/nodemailer": "^6.4.16",
    "prisma": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
